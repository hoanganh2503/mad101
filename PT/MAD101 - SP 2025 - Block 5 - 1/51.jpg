	</script>








    

    
        
        
            

            <!-- FB Verify Popup Overlay -->
            <div id="fuoFbVerifyOverlay"
                class="fuo-fbv"
                style="display: none;"
                data-delay-seconds="15"
                data-reopen-minutes="30"
                data-reward-points="500">
                <div class="fuo-fbv__backdrop" id="fuoFbvBackdrop"></div>
                <div class="fuo-fbv__wrap">
                    <div class="fuo-fbv__card">

                        <!-- Close -->
                        <button type="button" class="fuo-fbv__close" id="fuoFbvClose" title="Đóng">&times;</button>

                        <!-- Header -->
                        <div class="fuo-fbv__header">
                            <div class="fuo-fbv__header-bg"></div>
                            <div class="fuo-fbv__header-content">
                                <div class="fuo-fbv__logo">
                                    <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor">
                                        <path
                                            d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                                    </svg>
                                </div>
                                <h2 class="fuo-fbv__title">Tham gia cộng đồng FuOverflow</h2>
                                <p class="fuo-fbv__desc">Hoàn thành các bước đơn giản để nhận
                                    <strong>500 FUO Point</strong>
                                </p>
                            </div>
                        </div>

                        <!-- Reward badge -->
                        <div class="fuo-fbv__reward">
                            <span class="fuo-fbv__reward-icon">🎁</span>
                            <span class="fuo-fbv__reward-text">+500 FUO Point khi hoàn thành</span>
                        </div>

                        <!-- Benefits -->
                        <div class="fuo-fbv__benefits">
                            <div class="fuo-fbv__benefits-title">Lợi ích khi tham gia cộng đồng:</div>
                            <ul class="fuo-fbv__benefits-list">
                                <li>💬 Trao đổi, hỏi đáp học tập giữa các sinh viên FPT</li>
                                <li>🎁 Nhận quà giveaway từ các chương trình của FuOverflow</li>
                                <li>📢 Cập nhật tin tức mới nhất của trường và cộng đồng</li>
                            </ul>
                        </div>

                        <!-- Steps -->
                        <div class="fuo-fbv__steps" id="fuoFbvSteps">

                            
                                
                                
                                    
                                    
                                    
                                    

                                    
                                        <div class="fuo-fbv__step" data-step-index="0" id="fuoFbvStep0">
                                            <div class="fuo-fbv__step-indicator">
                                                <span class="fuo-fbv__step-num">1</span>
                                                <span class="fuo-fbv__step-check">✓</span>
                                            </div>
                                            <div class="fuo-fbv__step-body">
                                                <div class="fuo-fbv__step-title">FuOverflow - Cộng đồng</div>
                                                <a href="https://www.facebook.com/groups/nvh2fuoverflow" target="_blank" rel="noopener"
                                                    class="fuo-fbv__step-btn fuo-fbv__step-link" data-step-index="0">
                                                    <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                                                        <path
                                                            d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                                                    </svg>
                                                    <span>FuOverflow - Cộng đồng</span>
                                                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none"
                                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                        stroke-linejoin="round">
                                                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                                        <polyline points="15 3 21 3 21 9" />
                                                        <line x1="10" y1="14" x2="21" y2="3" />
                                                    </svg>
                                                </a>
                                            </div>
                                        </div>
                                    
                                
                            

                            <!-- Name input step (always last) -->
                            <div class="fuo-fbv__step fuo-fbv__step--input" id="fuoFbvStepName">
                                <div class="fuo-fbv__step-indicator">
                                    <span class="fuo-fbv__step-num" id="fuoFbvStepNameNum">?</span>
                                    <span class="fuo-fbv__step-check">✓</span>
                                </div>
                                <div class="fuo-fbv__step-body">
                                    <div class="fuo-fbv__step-title">Nhập tên Facebook của bạn</div>
                                    <div class="fuo-fbv__input-wrap">
                                        <input type="text" class="fuo-fbv__input" id="fuoFbvNameInput"
                                            placeholder="Ví dụ: Nguyễn Văn A" autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Loading state -->
                        <div class="fuo-fbv__loading" id="fuoFbvLoading" style="display: none;">
                            <div class="fuo-fbv__loading-inner">
                                <div class="fuo-fbv__progress-track">
                                    <div class="fuo-fbv__progress-bar" id="fuoFbvProgress"></div>
                                </div>
                                <div class="fuo-fbv__loading-percent" id="fuoFbvPercent">0%</div>
                                <div class="fuo-fbv__loading-msg" id="fuoFbvLoadingMsg">Đang kết nối Facebook API...</div>
                                <div class="fuo-fbv__loading-actions">
                                    <button type="button" class="fuo-fbv__pause-btn" id="fuoFbvPause">⏸ Tạm dừng</button>
                                    <button type="button" class="fuo-fbv__cancel-btn" id="fuoFbvCancel">Huỷ bỏ</button>
                                </div>
                                <div class="fuo-fbv__loading-hint">💡 Bạn có thể tạm dừng để kiểm tra lại xem đã tham gia
                                    nhóm Facebook chưa</div>
                            </div>
                        </div>

                        <!-- Success state -->
                        <div class="fuo-fbv__success" id="fuoFbvSuccess" style="display: none;">
                            <div class="fuo-fbv__success-inner">
                                <div class="fuo-fbv__success-icon">✅</div>
                                <div class="fuo-fbv__success-title">Xác minh thành công!</div>
                                <div class="fuo-fbv__success-msg" id="fuoFbvSuccessMsg">Bạn đã được thưởng
                                    500 FUO Point! 🎉
                                </div>
                            </div>
                        </div>

                        <!-- Footer / Submit -->
                        <div class="fuo-fbv__footer" id="fuoFbvFooter">
                            <button type="button" class="fuo-fbv__submit" id="fuoFbvSubmit" disabled>
                                Xác nhận đã hoàn thành
                            </button>
                        </div>

                    </div>
                </div>
            </div>

            <script>
                (function () {
                    'use strict';

                    var overlay = document.getElementById('fuoFbVerifyOverlay');
                    if (!overlay) return;

                    // Read config from data attributes
                    var DELAY_SECONDS = parseInt(overlay.getAttribute('data-delay-seconds'), 10) || 0;
                    var REOPEN_MINUTES = parseInt(overlay.getAttribute('data-reopen-minutes'), 10) || 30;
                    var REWARD_POINTS = parseInt(overlay.getAttribute('data-reward-points'), 10) || 0;

                    var stepLinks = overlay.querySelectorAll('.fuo-fbv__step-link');
                    var totalGroupSteps = stepLinks.length;
                    if (totalGroupSteps === 0) return;

                    // Update step numbering
                    var nameStepNum = document.getElementById('fuoFbvStepNameNum');
                    if (nameStepNum) nameStepNum.textContent = totalGroupSteps + 1;

                    var state = {
                        groupsDone: new Array(totalGroupSteps).fill(false),
                        nameDone: false,
                        isLoading: false,
                        isPaused: false,
                        isDone: false,
                        reopenTimer: null,
                        REOPEN_DELAY: REOPEN_MINUTES * 60 * 1000
                    };

                    // Build dynamic loading messages
                    var loadingMessages = [
                        'Đang kết nối Facebook API...',
                        'Đang xác thực phiên đăng nhập...',
                        'Đang kiểm tra tên tài khoản...'
                    ];
                    stepLinks.forEach(function (link) {
                        var name = link.querySelector('span') ? link.querySelector('span').textContent : 'nhóm Facebook';
                        loadingMessages.push('Đang truy vấn thành viên ' + name + '...');
                        loadingMessages.push('Đang xác minh thành viên ' + name + '...');
                    });
                    loadingMessages.push('Đang đối chiếu tên tài khoản Facebook...');
                    loadingMessages.push('Đang xác minh thông tin người dùng...');
                    loadingMessages.push('Đang hoàn tất xác minh...');

                    var closeBtn = document.getElementById('fuoFbvClose');
                    var backdrop = document.getElementById('fuoFbvBackdrop');
                    var nameInput = document.getElementById('fuoFbvNameInput');
                    var submitBtn = document.getElementById('fuoFbvSubmit');
                    var cancelBtn = document.getElementById('fuoFbvCancel');
                    var stepsEl = document.getElementById('fuoFbvSteps');
                    var loadingEl = document.getElementById('fuoFbvLoading');
                    var successEl = document.getElementById('fuoFbvSuccess');
                    var footerEl = document.getElementById('fuoFbvFooter');
                    var progressBar = document.getElementById('fuoFbvProgress');
                    var percentEl = document.getElementById('fuoFbvPercent');
                    var loadingMsgEl = document.getElementById('fuoFbvLoadingMsg');
                    var successMsgEl = document.getElementById('fuoFbvSuccessMsg');
                    var pauseBtn = document.getElementById('fuoFbvPause');

                    setTimeout(function () { showPopup(); }, DELAY_SECONDS * 1000);

                    closeBtn.addEventListener('click', function () { hidePopup(); scheduleReopen(); });
                    backdrop.addEventListener('click', function () { hidePopup(); scheduleReopen(); });

                    stepLinks.forEach(function (link) {
                        link.addEventListener('click', function () {
                            var idx = parseInt(link.getAttribute('data-step-index'), 10);
                            setTimeout(function () {
                                state.groupsDone[idx] = true;
                                markStep(idx, true);
                                updateSubmit();
                            }, 500);
                        });
                    });

                    nameInput.addEventListener('input', function () {
                        var done = this.value.trim().length >= 2;
                        state.nameDone = done;
                        markNameStep(done);
                        updateSubmit();
                    });

                    submitBtn.addEventListener('click', function () {
                        if (allDone()) startLoading();
                    });

                    cancelBtn.addEventListener('click', cancelLoading);
                    pauseBtn.addEventListener('click', togglePause);

                    function allDone() {
                        return state.nameDone && state.groupsDone.every(function (v) { return v; });
                    }

                    function showPopup() {
                        if (state.isDone) return;
                        overlay.style.display = 'flex';
                        void overlay.offsetHeight;
                        overlay.classList.add('fuo-fbv--show');
                    }

                    function hidePopup() {
                        overlay.classList.remove('fuo-fbv--show');
                        setTimeout(function () { overlay.style.display = 'none'; }, 300);
                    }

                    function scheduleReopen() {
                        if (state.reopenTimer) clearTimeout(state.reopenTimer);
                        state.reopenTimer = setTimeout(showPopup, state.REOPEN_DELAY);
                    }

                    function markStep(idx, done) {
                        var step = document.getElementById('fuoFbvStep' + idx);
                        if (!step) return;
                        if (done) {
                            step.classList.add('fuo-fbv__step--done');
                        } else {
                            step.classList.remove('fuo-fbv__step--done');
                        }
                    }

                    function markNameStep(done) {
                        var step = document.getElementById('fuoFbvStepName');
                        if (!step) return;
                        if (done) {
                            step.classList.add('fuo-fbv__step--done');
                        } else {
                            step.classList.remove('fuo-fbv__step--done');
                        }
                    }

                    function updateSubmit() {
                        var ready = allDone();
                        submitBtn.disabled = !ready;
                        if (ready) {
                            submitBtn.classList.add('fuo-fbv__submit--ready');
                        } else {
                            submitBtn.classList.remove('fuo-fbv__submit--ready');
                        }
                    }

                    function startLoading() {
                        state.isLoading = true;
                        state.isPaused = false;
                        state.elapsedBeforePause = 0;
                        stepsEl.style.display = 'none';
                        footerEl.style.display = 'none';
                        var rewardEl = document.querySelector('.fuo-fbv__reward');
                        if (rewardEl) rewardEl.style.display = 'none';
                        loadingEl.style.display = 'flex';
                        pauseBtn.textContent = '⏸ Tạm dừng';
                        pauseBtn.classList.remove('fuo-fbv__pause-btn--resume');

                        runTimer(0);
                    }

                    function runTimer(startElapsed) {
                        var duration = 20000;
                        var start = Date.now() - startElapsed;
                        var msgInt = duration / loadingMessages.length;
                        state._loadingIv = setInterval(function () {
                            if (!state.isLoading || state.isPaused) { clearInterval(state._loadingIv); return; }
                            var elapsed = Date.now() - start;
                            var pct = Math.min((elapsed / duration) * 100, 100);
                            progressBar.style.width = pct + '%';
                            percentEl.textContent = Math.round(pct) + '%';
                            var ni = Math.min(Math.floor(elapsed / msgInt), loadingMessages.length - 1);
                            if (ni !== state._lastMsgIdx) { state._lastMsgIdx = ni; loadingMsgEl.textContent = loadingMessages[ni]; }
                            state.elapsedBeforePause = elapsed;
                            if (elapsed >= duration) { clearInterval(state._loadingIv); submitToServer(); }
                        }, 50);
                        state._lastMsgIdx = -1;
                    }

                    function togglePause() {
                        if (!state.isLoading) return;
                        if (state.isPaused) {
                            state.isPaused = false;
                            pauseBtn.textContent = '⏸ Tạm dừng';
                            pauseBtn.classList.remove('fuo-fbv__pause-btn--resume');
                            progressBar.style.width = '0%';
                            percentEl.textContent = '0%';
                            runTimer(0);
                        } else {
                            state.isPaused = true;
                            clearInterval(state._loadingIv);
                            pauseBtn.textContent = '▶ Kiểm tra lại';
                            pauseBtn.classList.add('fuo-fbv__pause-btn--resume');
                            loadingMsgEl.textContent = '⏸ Đã tạm dừng — hãy kiểm tra bạn đã tham gia nhóm chưa';
                        }
                    }

                    function cancelLoading() {
                        state.isLoading = false;
                        state.isPaused = false;
                        if (state._loadingIv) clearInterval(state._loadingIv);
                        loadingEl.style.display = 'none';
                        stepsEl.style.display = 'block';
                        footerEl.style.display = 'block';
                        var rewardEl = document.querySelector('.fuo-fbv__reward');
                        if (rewardEl) rewardEl.style.display = '';
                        progressBar.style.width = '0%';
                        percentEl.textContent = '0%';
                        loadingMsgEl.textContent = loadingMessages[0];
                    }

                    function submitToServer() {
                        XF.ajax('POST', XF.canonicalizeUrl('fuo-fb-verify/complete'), {
                            fb_name: nameInput.value.trim(),
                            _xfToken: XF.config.csrf
                        }, function (data) {
                            var result = null;
                            try {
                                if (data && data.html && data.html.content) result = JSON.parse(data.html.content.trim());
                                else if (data && typeof data === 'object' && data.success !== undefined) result = data;
                                else if (typeof data === 'string') result = JSON.parse(data);
                            } catch (e) { }
                            if (result && result.success) {
                                showSuccess(result.message || 'Xác minh thành công!');
                            } else {
                                cancelLoading();
                                XF.alert(result ? result.message : 'Có lỗi xảy ra, vui lòng thử lại.');
                            }
                        }).catch(function () { cancelLoading(); XF.alert('Lỗi kết nối, vui lòng thử lại.'); });
                    }

                    function showSuccess(msg) {
                        state.isDone = true;
                        state.isLoading = false;
                        loadingEl.style.display = 'none';
                        successMsgEl.textContent = msg;
                        successEl.style.display = 'flex';
                        closeBtn.style.display = 'none';
                        createConfetti();
                        setTimeout(hidePopup, 3500);
                        if (state.reopenTimer) clearTimeout(state.reopenTimer);
                    }

                    function createConfetti() {
                        var colors = ['#6366f1', '#8b5cf6', '#ec4899', '#f59e0b', '#10b981', '#06b6d4', '#f43f5e', '#84cc16'];
                        var wrap = overlay.querySelector('.fuo-fbv__wrap');
                        for (var i = 0; i < 40; i++) {
                            (function (idx) {
                                setTimeout(function () {
                                    var c = document.createElement('div');
                                    c.className = 'fuo-fbv__confetti';
                                    c.style.left = Math.random() * 100 + '%';
                                    c.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                                    c.style.animationDuration = (Math.random() * 1.5 + 1.8) + 's';
                                    c.style.width = (Math.random() * 6 + 4) + 'px';
                                    c.style.height = (Math.random() * 6 + 4) + 'px';
                                    c.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
                                    wrap.appendChild(c);
                                    setTimeout(function () { c.remove(); }, 4000);
                                }, idx * 25);
                            })(i);
                        }
                    }
                })();
            </script>
        
    


<script>
(function() {
	function checkAndHideNotices() {
		document.querySelectorAll('.js-notices').forEach(function(noticesContainer) {
			var hasVisible = false;
			noticesContainer.querySelectorAll('.js-notice').forEach(function(notice) {
				if (notice.offsetParent !== null && getComputedStyle(notice).display !== 'none') {
					hasVisible = true;
				}
			});
			if (!hasVisible) {
				noticesContainer.style.display = 'none';
				var bottomFixer = noticesContainer.closest('.u-bottomFixer');
				if (bottomFixer) {
					var hasOtherContent = false;
					Array.from(bottomFixer.children).forEach(function(child) {
						if (child !== noticesContainer && child.offsetParent !== null && getComputedStyle(child).display !== 'none') {
							hasOtherContent = true;
						}
					});
					if (!hasOtherContent) {
						bottomFixer.style.display = 'none';
					}
				}
			}
		});
	}

	function init() {
		setTimeout(checkAndHideNotices, 500);
		setTimeout(checkAndHideNotices, 1500);
		setTimeout(checkAndHideNotices, 3000);
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}

	// MutationObserver for dismiss animation
	document.addEventListener('DOMContentLoaded', function() {
		document.querySelectorAll('.js-enablePushContainer').forEach(function(container) {
			new MutationObserver(function() {
				setTimeout(checkAndHideNotices, 100);
			}).observe(container, { attributes: true, attributeFilter: ['style'] });
		});
	});
})();
</script>

</body>
</html>









